{
  "name": "clinic-appointment-system",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -k -n server,client -c red,blue \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client start",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
